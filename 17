programa
{
    funcao inicio()
    {
        real altura, peso
        caracter sexo

        escreva("Digite a altura: ")
        leia(altura)

        escreva("Digite o sexo (M ou F): ")
        leia(sexo)

        se (sexo == 'M')
        {
            peso = (72.7 * altura) - 58
            escreva("Peso ideal: ", peso, " kg")
        }
        senao
        {
            peso = (62.1 * altura) - 44.7
            escreva("Peso ideal: ", peso, " kg")
        }
    }
}
