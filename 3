programa
{
    funcao inicio()
    {
        inteiro ano, mes, dia, total_Dias

        escreva("Digite  a sua idade: ")
        leia(ano)

        escreva("Digite o mes do seu aniversasrio: ")
        leia(mes)

        escreva("Digite o dia  do seu aniversario: ")
        leia(dia)

        total_Dias = (ano * 365) + (mes * 30) + dia

        escreva("A idade expressa  em dias é : ", total_Dias)
    }
}
