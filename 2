programa
{
    funcao inicio()
    {
        inteiro A, B, C
        inteiro R, S, D

        escreva("Digite A: ")
        leia(A)

        escreva("Digite B: ")
        leia(B)

        escreva("Digite C: ")
        leia(C)

        R = (A + B) * (A + B)
        S = (B + C) * (B + C)
        D = (R + S) / 2

        escreva("R = ", R, "\n")
        escreva("S = ", S, "\n")
        escreva("D = ", D)
    }
}
