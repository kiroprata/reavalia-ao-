programa
{
    funcao inicio()
    {
        inteiro totalSegundos, horas, minutos, segundos, resto

        escreva("Digite o tempo em segundos: ")
        leia(totalSegundos)

        horas = totalSegundos / 3600
        resto = totalSegundos - (horas * 3600)
        minutos = resto / 60
        segundos = resto - (minutos * 60)

        escreva("Tempo: ", horas, " horas, ",
         minutos, " minutos e ",
          segundos, " segundos.")
    }
}

