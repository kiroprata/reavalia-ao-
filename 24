programa
{
    funcao inicio()
    {
        inteiro inicio, fim, duracao

        escreva("Digite a hora de início: ")
        leia(inicio)

        escreva("Digite a hora de término: ")
        leia(fim)

        se (fim > inicio)
        {
            duracao = fim - inicio
        }
        senao
        {
            duracao = (24 - inicio) + fim
        }

        escreva("A duração do jogo foi de ", duracao, " horas.")
    }
}
